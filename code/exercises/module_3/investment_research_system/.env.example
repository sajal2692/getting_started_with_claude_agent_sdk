# By default this course uses your Claude Pro/Max SUBSCRIPTION -- no API key needed.
# Install the Claude Code CLI and run `claude` once to log in.
#
# OPTIONAL: to use per-token API billing instead, uncomment the line below and add
# a key from https://console.anthropic.com/settings/keys
# (If ANTHROPIC_API_KEY is set, it OVERRIDES your subscription.)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily Search API key (optional) -- enables the real-time news-search MCP used by
# the News & Sentiment subagent. Without it, that subagent uses the news-sentiment
# skill only. Get a free key (1000 searches/month) at https://tavily.com/
# TAVILY_API_KEY=your_tavily_api_key_here

# Maximum output tokens for the agent's responses (optional). Only relevant with
# per-token API billing (ANTHROPIC_API_KEY). Raise this if a large dashboard is
# truncated; the subscription path is unaffected and the default suits most runs.
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
